{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "API Key Manager",
  "version": "1.0.0",
  "identifier": "com.apikeymanager.app",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:39871",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "API Key Manager",
        "width": 960,
        "height": 820,
        "minWidth": 720,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "icon": "../build/icon.png",
        "url": "index.html"
      },
      {
        "label": "widget",
        "title": "API Key Widget",
        "width": 60,
        "height": 60,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "icon": "../build/icon.png",
        "url": "widget.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' https: http:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../build/icon.png"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "category": "Utility",
    "shortDescription": "Manage API keys for any AI provider",
    "longDescription": "A desktop application to manage API keys for any AI provider with a desktop widget."
  }
}
